# ===========================================================================
# Auri — Environment Variables
# ===========================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# ===========================================================================

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DB_HOST=db
DB_PORT=5432
DB_USER=auri
DB_PASSWORD=change_me_in_production
DB_NAME=auri
DATABASE_URL=postgresql+asyncpg://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
SECRET_KEY=generate_a_random_secret_key_here
ENCRYPTION_KEY=generate_a_32_byte_hex_key_for_pgcrypto

# ---------------------------------------------------------------------------
# Telegram Bot
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here      # also set BOT_TOKEN above
BOT_TOKEN=${TELEGRAM_BOT_TOKEN}
MODERATOR_TELEGRAM_CHAT_ID=your_moderator_telegram_chat_id_here  # flagged confessions relay here
MODERATION_API_KEY=generate_a_random_shared_secret_for_the_bot_to_use
MODERATION_POLL_SECONDS=30  # bot: how often to poll the backend moderation queue
BACKEND_URL=http://localhost:8000  # bot: base URL of the Auri backend API
WEBHOOK_URL=https://your-domain.com/webhook
WEBHOOK_SECRET=generate_a_random_webhook_secret_here  # required when ENVIRONMENT=production
PORT=8080
HOST=0.0.0.0

# ---------------------------------------------------------------------------
# Recipient directory (comma-separated, admin-managed — no LDAP/HRIS)
# ---------------------------------------------------------------------------
DEPARTMENTS=HR,Engineering,Management

# ---------------------------------------------------------------------------
# Data retention — purge forwarded/deleted confessions this many hours after
# their last update. Run via cron/k8s CronJob: python -m app.services.retention
# ---------------------------------------------------------------------------
RETENTION_HOURS=24

# ---------------------------------------------------------------------------
# LLM (OpenAI — default PII de-identification / categorisation / summarisation provider)
# ---------------------------------------------------------------------------
LLM_API_KEY=your_openai_api_key_here
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048

# ---------------------------------------------------------------------------
# Audio / STT / TTS
# ---------------------------------------------------------------------------
WHISPER_MODEL=base
EDGE_TTS_VOICE=en-US-JennyNeural

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
SENTRY_DSN=  # optional — empty disables Sentry entirely; /metrics is always on

# ---------------------------------------------------------------------------
# CORS / Rate Limiting
# ---------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:8081
CONFESSION_RATE_LIMIT_SECONDS=300

# ---------------------------------------------------------------------------
# Runtime
# ---------------------------------------------------------------------------
ENVIRONMENT=development
