# Auri Backend - Environment Variables
# Copy this file to .env and fill in real values.

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=auri
DB_USER=auri
DB_PASS=your_database_password_here

# Security
SECRET_KEY=change-me-to-a-long-random-string

# Speech-to-Text
WHISPER_MODEL=base

# LLM
LLM_API_KEY=sk-your-openai-or-anthropic-api-key
LLM_MODEL=gpt-4o-mini

# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
MODERATOR_TELEGRAM_CHAT_ID=your-moderator-telegram-chat-id-here
MODERATION_API_KEY=generate-a-random-shared-secret-for-the-bot-to-use

# Recipient directory (comma-separated, admin-managed)
DEPARTMENTS=HR,Engineering,Management

# Environment / Logging
ENVIRONMENT=development
LOG_LEVEL=INFO
